{
  "version": 2,
  "builds": [
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "outputDirectory": ".",
  "redirects": [
    {
      "source": "/app",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*([aA]ndroid).*"
        }
      ],
      "destination": "https://play.google.com/store/apps/details?id=sa.calma.realestate",
      "permanent": false
    },
    {
      "source": "/app",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*([iI][pP]ad|[iI][pP]hone|[iI][pP]od).*"
        }
      ],
      "destination": "https://apps.apple.com/us/app/calma-real-estate/id6755458800",
      "permanent": false
    },
    {
      "source": "/app",
      "destination": "https://calma.sa",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/:path((?!en/|images/|css/|js/|fonts/|videos/|esign/).*)",
      "destination": "/:path.html"
    }
  ],
  "headers": [
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000" }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000" }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/esign/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=120, stale-while-revalidate=600" }
      ]
    }
  ]
}
